# Copie para .env.local e preencha os valores. NUNCA commitar .env.local (está no .gitignore).
# Secrets reais ficam só em .env.local (dev) e nas Environment Variables da Vercel (prod).

# Supabase
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server-side apenas — nunca exposto no browser

# OpenRouter (agente de IA — tutor + advisor). Chamadas SEMPRE server-side.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# DeepSeek (Tutor conversacional). Chamadas SEMPRE server-side.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ----- Inferência online (opcional, experimental) — ADR-0017 -----
# Liga o uso do XGBoost REAL (via ONNX, rota /api/infer-onnx) como "Projeção" no
# Simulador Vivo. Desligada por padrão → o simulador usa a heurística transparente
# ancorada (ADR-0014). "1" ou "true" liga. Pública: chega ao browser (NEXT_PUBLIC_).
NEXT_PUBLIC_ONLINE_INFERENCE=

# ----- Voz (Text-to-Speech) — server-side; segredos NUNCA no frontend -----
# Se nenhum provedor tiver credencial, o app cai automaticamente na voz do
# navegador (modo degradado, sem quebrar o chat). Ver docs/voice-tts.md.
TTS_ENABLED=true
AUDIO_AUTOPLAY=true
TTS_PROVIDER=elevenlabs           # provedor principal: elevenlabs | google
TTS_FALLBACK_PROVIDER=google      # fallback automático: elevenlabs | google
# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# Google Cloud Text-to-Speech (escolha UMA forma de autenticação):
#  (1) chave de API simples:
GOOGLE_TTS_API_KEY=
#  (2) OU service account (cole o JSON inteiro nesta env, server-side):
GOOGLE_APPLICATION_CREDENTIALS_JSON=
GOOGLE_TTS_LANGUAGE_CODE=pt-BR
GOOGLE_TTS_VOICE_NAME=pt-BR-Neural2-C
